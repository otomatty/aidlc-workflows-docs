---
import { getCollection } from "astro:content";

import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/routes";

const docsEntries = await getCollection("docs");
const docsIndexEntry = docsEntries.find((entry) => entry.id === "index");
const sourceCommit = docsIndexEntry?.data.sourceCommit ?? "";
const sourceCommitShort = sourceCommit.slice(0, 7);
const sourceHref = sourceCommit
	? `https://github.com/awslabs/aidlc-workflows/blob/${sourceCommit}/docs/README.md`
	: undefined;
const docsHref = withBase("/docs/");
const changelogHref = withBase("/changelog/");
const guideCards = [
	{
		title: "ユーザーガイド",
		description:
			"AI-DLC を使ってソフトウェアを進める人向けの入口です。導入、ワークフロー、スコープ、学習ループを追えます。",
		href: `${docsHref}#user-guide`,
	},
	{
		title: "ハーネスエンジニアガイド",
		description:
			"チーム向けに AI-DLC の振る舞いを整える人向けです。ステージ、エージェント、スコープ、センサーの調整方針を辿れます。",
		href: `${docsHref}#harness-engineer-guide`,
	},
	{
		title: "開発者リファレンス",
		description:
			"AI-DLC 自体を変更する人向けです。エンジン、フック、CLI ツール、テスト戦略の全体像を確認できます。",
		href: `${docsHref}#developer-reference`,
	},
] as const;
---

<BaseLayout title="AI-DLC ドキュメント">
	<Header />
	<main id="main-content" class="page-shell">
		<section class="surface-card hero-grid landing-hero">
			<div class="landing-hero__copy">
				<p class="eyebrow">Astro ドキュメント UI</p>
				<h1>AI-DLC ドキュメント</h1>
				<p>
					AI-DLC は、AI 駆動ソフトウェア開発を構造化されたフェーズと承認ゲートで進める方法論です。このサイトは、その
					ネイティブなマルチハーネス実装である
					`awslabs/aidlc-workflows`
					を日本語で読み進めるための入口です。
				</p>
				<div class="landing-actions">
					<a class="primary-link" href={docsHref}>ドキュメント一覧を開く</a>
					<a class="primary-link" href={changelogHref}>変更履歴を見る</a>
				</div>
			</div>
			<div class="landing-hero__panel">
				<p class="eyebrow">Quick Start</p>
				<pre><code>/aidlc Build a REST API for inventory management</code></pre>
				<p>
					1 つのコマンドから、要件整理、設計、実装、テスト、運用までのワークフローを段階的に進めます。
				</p>
				{sourceHref && (
					<p class="landing-source">
						同期元:
						<a href={sourceHref}>docs/README.md @{sourceCommitShort}</a>
					</p>
				)}
			</div>
		</section>

		<section class="card-grid landing-stats" aria-label="AI-DLC の主要指標">
			<article class="surface-card stat-card">
				<h2>5フェーズ</h2>
				<p>Initialization から Operation まで、32 ステージを段階的に進めます。</p>
			</article>
			<article class="surface-card stat-card">
				<h2>14エージェント</h2>
				<p>11 のドメインエキスパートに、2 つのレビュアーと 1 つのコンポーザーを加えた編成です。</p>
			</article>
			<article class="surface-card stat-card">
				<h2>4ハーネス</h2>
				<p>Claude Code、Kiro IDE、Kiro CLI、Codex CLI を同じ `core/` から生成します。</p>
			</article>
			<article class="surface-card stat-card">
				<h2>9スコープ</h2>
				<p>enterprise から workshop までを深度とテスト戦略の設定と組み合わせて使い分けます。</p>
			</article>
		</section>

		<section class="landing-section">
			<div class="landing-section__header">
				<p class="eyebrow">ガイド入口</p>
				<h2>3つのガイド</h2>
				<p>目的に応じて、利用者向け、チーム調整向け、実装変更向けの 3 系統から読み始められます。</p>
			</div>
			<div class="card-grid">
				{guideCards.map((guide) => (
					<article class="surface-card guide-card">
						<h3>
							<a href={guide.href}>{guide.title}</a>
						</h3>
						<p>{guide.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="landing-section" aria-labelledby="overview-heading">
			<div class="landing-section__header">
				<p class="eyebrow">概要</p>
				<h2 id="overview-heading">AI-DLC を理解する</h2>
			</div>
			<div class="card-grid topic-grid">
				<article class="surface-card topic-card">
					<h3>Small Mob, Broad Agents</h3>
					<p>
						狭い専門家を大量に連鎖させず、11 の幅広いドメインエージェントが複数フェーズを横断します。引き継ぎ境界を減らし、関連する判断の文脈を保つ設計です。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>なぜ AI-DLC か</h3>
					<p>
						アドホックな AI コーディングで失われやすい意図、判断理由、修正知見を、ステージ、承認ゲート、監査、学習ループとして残します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>リポジトリ構成</h3>
					<p>
						著述元は `core/`、ハーネス固有面は `harness/`、生成配布物は `dist/`。`docs/`
						が 3 ガイドを、`tests/` が検証層を保持します。
					</p>
				</article>
			</div>
		</section>

		<section id="architecture" class="landing-section">
			<div class="landing-section__header">
				<p class="eyebrow">アーキテクチャ</p>
				<h2>アーキテクチャの要点</h2>
			</div>
			<div class="card-grid topic-grid">
				<article class="surface-card topic-card">
					<h3>エンジンとコンダクター</h3>
					<p>
						Bun 製エンジンが状態とグラフから次の一手を決定し、ライブセッションのコンダクターが質問、ペルソナ、成果物作成、ゲート提示の品質を担います。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>型付きディレクティブ</h3>
					<p>
						`next` は `run-stage`、`dispatch-subagent`、`invoke-swarm`、`present-gate`
						など 9 種の判別可能な指示から、検証済みの 1 件だけを返します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>ガード機構</h3>
					<p>
						人間実在、成果物、レビュアー読取範囲、停止・自律モードの境界を決定論的に検査し、承認の捏造や不完全な完了を防ぎます。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>状態と監査</h3>
					<p>
						インテントごとの `aidlc-state.md` が進捗の単一情報源です。監査はクローン別シャードと現在の 71 イベント・19 カテゴリで判断と遷移を追跡します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>hooks・tools・sensors</h3>
					<p>
						12 フックがライフサイクルと制御境界を接続し、TypeScript CLI tools が状態を変更、4 センサーが成果物の構造・型・上流整合性を助言的に検査します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>プラグイン</h3>
					<p>
						`plugins/&lt;name&gt;/` から新規ステージと既存ステージへの加算的 contribution
						をハーネス別プラグインへ投影します。未導入時の core は変わりません。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>consumes / consumes_absent</h3>
					<p>
						存在する必須入力は `consumes`、欠落入力は `consumes_absent`
						へ分離し、スコープ上の意図的欠落と実行経路上の異常を `expected` で区別します。
					</p>
				</article>
			</div>
		</section>

		<section id="workflow" class="landing-section">
			<div class="landing-section__header">
				<p class="eyebrow">ワークフロー</p>
				<h2>ワークフローの要点</h2>
			</div>
			<div class="card-grid topic-grid">
				<article class="surface-card topic-card">
					<h3>ライフサイクル全体</h3>
					<p>
						5 フェーズ・32 ステージを順に進み、フェーズ境界でトレーサビリティを検査します。Operation の知見は次の Ideation へ戻せます。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>Phase 0: Initialization</h3>
					<p>
						3 ステージを 1 回の決定論的初期化で実行し、ワークスペース検出、状態、監査シャードを人間ゲートなしで準備します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>Phase 1: Ideation</h3>
					<p>
						7 ステージで意図、調査、実現可能性、スコープ、チーム、ラフモック、続行承認を扱い、取り組む価値と境界を固めます。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>Phase 2: Inception</h3>
					<p>
						8 ステージで既存コードと実践を理解し、要件・ストーリー・設計を Unit of Work と Bolt 計画へ分解します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>Phase 3: Construction</h3>
					<p>
						ステージ 3.1〜3.5 は Bolt ごとに実行します。最初の walking skeleton
						を確認して gated / autonomous を選び、3.6 Build and Test と 3.7 CI Pipeline
						は全 Bolt 完了後に 1 回だけ実行します（3.7 はスコープ対象時）。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>Phase 4: Operation</h3>
					<p>
						7 つの条件付きステージで配備、環境、可観測性、インシデント、性能、最適化を扱い、完了または次の Ideation へ接続します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>9つのスコープ</h3>
					<p>
						`enterprise`、`feature`、`mvp`、`poc`、`bugfix`、`refactor`、`infra`、`security-patch`、`workshop`
						が実行ステージを選びます。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>自由文からのスコープ検出</h3>
					<p>
						明確なキーワード一致は既存スコープの確認へ進み、豊かな記述や不一致は固定の feature 既定ではなくコンポーズ提案へ進みます。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>アダプティブコンポーザー</h3>
					<p>
						タスク、スキャンレポート、進行中プランから EXECUTE/SKIP グリッドを提案します。決定論的検証と人間承認が済むまで書き込みません。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>深度とテスト戦略</h3>
					<p>
						Minimal / Standard / Comprehensive の 3 段階を独立に指定し、成果物の詳しさとテスト量を別々に調整します。
					</p>
				</article>
			</div>
		</section>

		<section id="agents" class="landing-section">
			<div class="landing-section__header">
				<p class="eyebrow">エージェント</p>
				<h2>エージェントの要点</h2>
			</div>
			<div class="card-grid topic-grid">
				<article class="surface-card topic-card">
					<h3>役割とティア</h3>
					<p>
						14 体は 11 ドメイン、2 balanced レビュアー、1 composer。全体では 9 judgment、2 balanced、3 templated
						で、著述ティアを各ハーネスのモデル・effort 設定へ投影します。
					</p>
				</article>
				<article class="surface-card topic-card">
					<h3>ナレッジと情報の流れ</h3>
					<p>
						方法論ナレッジとチーム管理ナレッジを重ね、product → architect → developer → quality → deploy →
						operations の成果物連鎖をコンダクターが仲介します。運用知見は product へ還流します。
					</p>
				</article>
			</div>
		</section>

		<section class="landing-section">
			<div class="landing-section__header">
				<p class="eyebrow">Harnesses</p>
				<h2>対応ハーネス</h2>
			</div>
			<ul class="surface-card harness-list">
				<li><strong>Claude Code</strong> — `/aidlc` で起動する既定の例が最も多いハーネスです。</li>
				<li><strong>Kiro IDE</strong> — IDE のフックとチャット導線に統合された配布物を持ちます。</li>
				<li><strong>Kiro CLI</strong> — CLI セッション上で `/aidlc` を実行する配布物を持ちます。</li>
				<li><strong>Codex CLI</strong> — `dist/codex/` と `$aidlc` を使う配布物を持ちます。</li>
			</ul>
		</section>

		<section class="surface-card landing-section">
			<div class="landing-section__header">
				<p class="eyebrow">Historical Archive</p>
				<h2>旧サイトの履歴</h2>
				<p>
					旧 v2 ウォッチサイトの日本語 changelog は Markdown 化して保存しています。過去の要約を参照する場合は
					<a href={changelogHref}>変更履歴アーカイブ</a>
					を開いてください。
				</p>
			</div>
		</section>
		<Footer />
	</main>
</BaseLayout>
