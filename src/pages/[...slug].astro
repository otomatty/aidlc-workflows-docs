---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";

import DocsLayout from "../layouts/DocsLayout.astro";
import { buildNavigation, findPageNeighbors } from "../lib/navigation";
import { createDocsStaticPaths } from "../lib/routes";

export const getStaticPaths = (async () => {
	const docsEntries = await getCollection("docs");

	return createDocsStaticPaths(docsEntries.map((entry) => entry.id));
}) satisfies GetStaticPaths;

const { contentId } = Astro.props as { contentId: string };
const docsEntries = await getCollection("docs");
const entry = docsEntries.find(
	(candidate): candidate is CollectionEntry<"docs"> => candidate.id === contentId,
);

if (!entry) {
	throw new Error(`Missing docs content entry for "${contentId}".`);
}

const navigation = buildNavigation(
	docsEntries.map((docEntry) => ({
		id: docEntry.id,
		title: docEntry.data.title,
		sidebarOrder: docEntry.data.sidebarOrder,
	})),
);
const neighbors = findPageNeighbors(navigation, entry.id);
const { Content, headings } = await render(entry);
---

<DocsLayout
	contentId={entry.id}
	title={entry.data.title}
	description={entry.data.description}
	navigation={navigation}
	headings={headings}
	previous={neighbors.previous}
	next={neighbors.next}
	sourcePath={entry.data.sourcePath}
	sourceCommit={entry.data.sourceCommit}
	translationStatus={entry.data.translationStatus}
>
	<Content />
</DocsLayout>
