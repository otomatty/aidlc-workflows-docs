---
import { getCollection, render } from "astro:content";

import DocsLayout from "../../layouts/DocsLayout.astro";
import { buildNavigation, findPageNeighbors } from "../../lib/navigation";

const docsEntries = await getCollection("docs");
const entry = docsEntries.find((candidate) => candidate.id === "index");

if (!entry) {
	throw new Error("Missing docs index content entry.");
}

const navigation = buildNavigation(
	docsEntries.map((docEntry) => ({
		id: docEntry.id,
		title: docEntry.data.title,
		sidebarOrder: docEntry.data.sidebarOrder,
	})),
);
const neighbors = findPageNeighbors(navigation, entry.id);
const { Content, headings } = await render(entry);
---

<DocsLayout
	contentId={entry.id}
	title={entry.data.title}
	description={entry.data.description}
	navigation={navigation}
	headings={headings}
	previous={neighbors.previous}
	next={neighbors.next}
	sourcePath={entry.data.sourcePath}
	sourceCommit={entry.data.sourceCommit}
	translationStatus={entry.data.translationStatus}
>
	<Content />
</DocsLayout>
