---
import type { GuideNavigation } from "../lib/navigation";
import { withBase } from "../lib/routes";

interface Props {
	navigation: GuideNavigation[];
	currentContentId: string;
}

const { navigation, currentContentId } = Astro.props;
const docsHref = withBase("/docs/");
---

<div class="docs-mobile-nav">
	<button
		class="docs-mobile-nav__trigger"
		type="button"
		aria-expanded="false"
		aria-controls="mobile-navigation-panel"
		aria-haspopup="dialog"
		data-mobile-nav-trigger
	>
		ナビゲーションを開く
	</button>

	<div
		id="mobile-navigation-panel"
		class="docs-mobile-nav__panel"
		role="dialog"
		aria-label="モバイルナビゲーション"
		aria-modal="false"
		hidden
		data-mobile-nav
	>
		<div class="docs-mobile-nav__header">
			<h2>ドキュメントナビゲーション</h2>
			<button
				class="docs-mobile-nav__close"
				type="button"
				data-mobile-nav-close
			>
				閉じる
			</button>
		</div>
		<nav aria-label="モバイルナビゲーション">
			<a
				class:list={[
					"docs-mobile-nav__home",
					{ "is-current": currentContentId === "index" },
				]}
				href={docsHref}
				aria-current={currentContentId === "index" ? "page" : undefined}
			>
				AI-DLC ドキュメント
			</a>
			{
				navigation.map((group) => (
					<section class="docs-mobile-nav__group" aria-label={group.title}>
						<h3>{group.title}</h3>
						{group.sections.map((section) => (
							<div class="docs-mobile-nav__section">
								{section.title !== group.title && <h4>{section.title}</h4>}
								<ul>
									{section.links.map((link) => (
										<li>
											<a
												class:list={[
													"docs-mobile-nav__link",
													{ "is-current": link.id === currentContentId },
												]}
												href={link.href}
												aria-current={
													link.id === currentContentId ? "page" : undefined
												}
											>
												{link.title}
											</a>
										</li>
									))}
								</ul>
							</div>
						))}
					</section>
				))
			}
		</nav>
	</div>
</div>
