---
import { siteMetadata } from "../data/site";
import { withBase } from "../lib/routes";

const docsHref = withBase("/docs/");
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="site-brand" href={docsHref}>
			AI-DLC <span>ドキュメント</span>
		</a>
		<nav class="site-links" aria-label="サイト">
			<a href={docsHref}>{siteMetadata.labels.docs}</a>
			<a href={siteMetadata.upstreamRepositoryUrl}>{siteMetadata.labels.github}</a>
		</nav>
	</div>
</header>
