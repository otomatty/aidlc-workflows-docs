---
import type { NavLink } from "../lib/navigation";

interface Props {
	previous?: NavLink;
	next?: NavLink;
}

const { previous, next } = Astro.props;
---

{
	(previous || next) && (
		<nav class="page-navigation" aria-label="ページ送り">
			{previous ? (
				<a class="page-navigation__card" href={previous.href} rel="prev">
					<span class="page-navigation__label">前のページ</span>
					<strong>{previous.title}</strong>
				</a>
			) : (
				<div class="page-navigation__card is-empty" aria-hidden="true"></div>
			)}
			{next ? (
				<a class="page-navigation__card" href={next.href} rel="next">
					<span class="page-navigation__label">次のページ</span>
					<strong>{next.title}</strong>
				</a>
			) : (
				<div class="page-navigation__card is-empty" aria-hidden="true"></div>
			)}
		</nav>
	)
}
