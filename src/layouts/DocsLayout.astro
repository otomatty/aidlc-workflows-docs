---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Mermaid from "../components/Mermaid.astro";
import MobileNav from "../components/MobileNav.astro";
import PageNavigation from "../components/PageNavigation.astro";
import Search from "../components/Search.astro";
import Sidebar from "../components/Sidebar.astro";
import SourceStatus from "../components/SourceStatus.astro";
import TableOfContents from "../components/TableOfContents.astro";
import type { DocTranslationStatus } from "../content.config";
import { siteMetadata } from "../data/site";
import type { GuideNavigation, NavLink } from "../lib/navigation";
import BaseLayout from "./BaseLayout.astro";
import "../styles/docs.css";

interface HeadingLink {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	contentId: string;
	title: string;
	description: string;
	navigation: GuideNavigation[];
	headings: HeadingLink[];
	previous?: NavLink;
	next?: NavLink;
	sourcePath: string;
	sourceCommit: string;
	translationStatus: DocTranslationStatus;
}

const {
	contentId,
	title,
	description,
	navigation,
	headings,
	previous,
	next,
	sourcePath,
	sourceCommit,
	translationStatus,
} = Astro.props;
---

<BaseLayout
	title={`${title} | ${siteMetadata.title}`}
	description={description}
>
	<Header />
	<div class="docs-shell">
		<Sidebar navigation={navigation} currentContentId={contentId} />
		<div class="docs-main-column">
			<MobileNav navigation={navigation} currentContentId={contentId} />
			<main id="main-content" class="docs-main">
				<div class="docs-toolbar">
					<Breadcrumbs
						navigation={navigation}
						contentId={contentId}
						pageTitle={title}
					/>
					<Search />
				</div>
				<article class="doc-article">
					<header class="doc-article__header">
						<p class="doc-article__eyebrow">AI-DLC ドキュメント</p>
						<p class="doc-article__description">{description}</p>
					</header>
					<div class="doc-article__body">
						<slot />
					</div>
				</article>
				<SourceStatus
					sourcePath={sourcePath}
					sourceCommit={sourceCommit}
					translationStatus={translationStatus}
				/>
				<PageNavigation previous={previous} next={next} />
				<Footer />
			</main>
		</div>
		<TableOfContents headings={headings} />
	</div>
	<Mermaid />
	<script>
		import "../scripts/mobile-nav.ts";
	</script>
</BaseLayout>
